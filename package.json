{
  "name": "speedra",
  "version": "1.0.13",
  "description": "A beautiful, modern CLI tool for network performance testing using iperf3 with a stunning TUI interface",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xdearboy/speedra.git"
  },
  "homepage": "https://github.com/xdearboy/speedra",
  "bugs": {
    "url": "https://github.com/xdearboy/speedra/issues"
  },
  "author": "xdearboy",
  "bin": {
    "speedra": "dist/index.js"
  },
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc && node scripts/postbuild.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "lint": "biome lint src tests",
    "lint:fix": "biome lint --write src tests",
    "format": "biome format --write src tests",
    "format:check": "biome format src tests",
    "check": "biome check src tests",
    "check:fix": "biome check --write src tests"
  },
  "keywords": [
    "iperf3",
    "speedtest",
    "network",
    "cli",
    "tui",
    "bandwidth"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "dependencies": {
    "boxen": "8.0.1",
    "chalk": "5.6.2",
    "cli-spinners": "3.4.0",
    "date-fns": "4.1.0",
    "execa": "9.6.1",
    "figures": "6.1.0",
    "geoip-lite": "2.0.1",
    "geolib": "3.3.14",
    "gradient-string": "3.0.0",
    "ink": "7.0.1",
    "ink-big-text": "2.0.0",
    "ink-gradient": "4.0.0",
    "ink-spinner": "5.0.0",
    "react": "19.2.5",
    "react-devtools-core": "7.0.1",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "@emnapi/wasi-threads": "1.2.1",
    "@testing-library/react": "16.3.2",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "20.19.39",
    "@types/react": "19.2.14",
    "@vitest/coverage-v8": "4.1.5",
    "fast-check": "4.7.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}